# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DATABASE_URL: SQLite database used by Prisma for the backend API.
# Relative SQLite paths are resolved from prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# PORT: Express API port.
PORT="3001"

# CLIENT_ORIGIN: Preferred frontend origin allowed for local API requests.
# The server also accepts localhost, 127.0.0.1, private IPv4 LAN addresses,
# and simple local machine hostnames for easier same-network access.
CLIENT_ORIGIN="http://localhost:3000"

# VITE_API_BASE_URL: Optional explicit frontend API base URL.
# Leave unset to auto-use the current browser hostname on port 3001.
VITE_API_BASE_URL="http://localhost:3001/api"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
